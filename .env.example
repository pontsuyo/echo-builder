# Mistral Proxy Configuration
# Copy this file to .env and fill in your values

# Mistral API Key (required)
MISTRAL_API_KEY="your-mistral-api-key-here"

# Mistral API Base URL (optional, default: https://api.mistral.ai)
# MISTRAL_API_BASE="https://api.mistral.ai"

# Proxy Host (optional, default: 127.0.0.1)
# MISTRAL_PROXY_HOST="127.0.0.1"

# Proxy Port (optional, default: 8001)
# MISTRAL_PROXY_PORT="8001"

# CORS Origin (optional, default: *)
# MISTRAL_PROXY_CORS_ORIGIN="*"

# Log Level (optional, default: DEBUG)
# MISTRAL_PROXY_LOG_LEVEL="DEBUG"
